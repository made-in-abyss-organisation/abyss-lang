// Benchmark: a tight integer loop with a data-dependent LCG recurrence.
// The modulo keeps values bounded (no overflow) and the dependency chain
// stops a compiler from folding the loop to a closed form, so it measures
// real per-iteration arithmetic + loop throughput.
fn main() {
    var x = 1
    for i in 0..100000000 {
        x = (x * 1103515245 + 12345) % 2147483647
    }
    print(x)
}
